# Copy this file to .env and fill in your real DeepSeek API key
# DeepSeek provides an OpenAI-compatible API endpoint.
OPENAI_API_KEY=sk-...

# Supported models: deepseek-chat, deepseek-reasoner
MODEL=deepseek-chat
PORT=3001

# (Windows only) Path(s) to your GTK3 runtime bin folder used by WeasyPrint for
# PDF export, separated by ';'. The server already adds common locations
# (C:\GTK3-Runtime\bin, C:\Program Files\GTK3-Runtime Win64\bin, C:\msys64\mingw64\bin),
# so you normally don't need to set this. Use it only if GTK is installed elsewhere.
# WEASYPRINT_DLL_DIRECTORIES=C:\GTK3-Runtime\bin
